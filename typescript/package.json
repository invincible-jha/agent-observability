{
  "name": "@aumos/agent-observability",
  "version": "0.1.0",
  "description": "TypeScript client for the AumOS agent-observability framework — distributed tracing, cost attribution, and drift detection",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "keywords": [
    "aumos",
    "agent-observability",
    "opentelemetry",
    "tracing",
    "cost-attribution",
    "drift-detection",
    "llm-observability",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aumos-ai/agent-observability"
  }
}
